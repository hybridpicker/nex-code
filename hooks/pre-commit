#!/bin/bash
# pre-commit hook — blocks sensitive files/secrets and rebuilds dist/ when source files change.
# Install via: npm run install-hooks

set -euo pipefail

# ─── Load nvm so node/npm are available in non-interactive shells ──
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1091
  \. "$NVM_DIR/nvm.sh" 2>/dev/null || true
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [ "${NEX_SKIP_SECRET_CHECK:-0}" = "1" ]; then
  echo "[pre-commit] Secret check skipped (NEX_SKIP_SECRET_CHECK=1)"
else
  echo "[pre-commit] Scanning staged changes for secrets..."
  if ! (cd "$REPO_ROOT" && node scripts/secret-scan.js --staged); then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  SECRET DETECTED — commit blocked                      ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  Move secrets to local-only config before committing.  ║"
    echo "║  Bypass: NEX_SKIP_SECRET_CHECK=1 git commit            ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
fi

# Check if any source files that affect the bundle are staged
STAGED_SOURCE=$(git diff --cached --name-only | grep -E '^cli/|^scripts/build\.js' || true)

if [ -z "$STAGED_SOURCE" ]; then
  exit 0
fi

echo "[pre-commit] Source files changed — rebuilding dist/..."
if ! (cd "$REPO_ROOT" && npm run build 2>&1 | tail -3); then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  BUILD FAILED — commit blocked                          ║"
  echo "╠══════════════════════════════════════════════════════════╣"
  echo "║  Fix the build error and try again.                     ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

git add dist/nex-code.js dist/benchmark.js dist/background-worker.js
echo "[pre-commit] dist/ rebuilt and staged — source + dist will land in one commit."
