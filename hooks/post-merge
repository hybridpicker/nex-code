#!/bin/bash
# post-merge hook — auto version bump on devel→main merge + npm install + auto-publish
# Install via: npm run install-hooks

set -euo pipefail

BRANCH=$(git branch --show-current 2>/dev/null || true)

# Only act on main branch
if [ "$BRANCH" != "main" ]; then
  exit 0
fi

# Check if the merge came from devel
MERGE_MSG=$(git log --merges -1 --format=%s 2>/dev/null || true)
if echo "$MERGE_MSG" | grep -qi "devel"; then
  # Safety net: verify CI passed for the devel commit that was merged.
  # The second parent of a merge commit is the branch tip that was merged in.
  DEVEL_SHA=$(git log --merges -1 --format="%P" 2>/dev/null | awk '{print $2}')
  if [ -n "$DEVEL_SHA" ] && command -v gh &>/dev/null; then
    SHORT_SHA="${DEVEL_SHA:0:8}"
    echo "[post-merge] Verifying CI status for merged devel @ ${SHORT_SHA}..."
    CI_JSON=$(gh run list \
      --workflow "CI" \
      --commit "$DEVEL_SHA" \
      --limit 1 \
      --json conclusion,status \
      2>/dev/null || echo "[]")
    CI_STATUS=$(echo "$CI_JSON" | node -e "
const runs = JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
if (!runs.length) { console.log('no_run'); process.exit(0); }
const r = runs[0];
if (r.status !== 'completed') { console.log(r.status); } else { console.log(r.conclusion); }
" 2>/dev/null || echo "unknown")
    if [ "$CI_STATUS" != "success" ] && [ "$CI_STATUS" != "no_run" ]; then
      echo "[post-merge] ABORT: CI status for devel @ ${SHORT_SHA} is '${CI_STATUS}'."
      echo "[post-merge] The merge has been recorded locally but publish is blocked."
      echo "[post-merge] Fix CI on devel, then use: npm run merge-to-main"
      exit 1
    elif [ "$CI_STATUS" = "no_run" ]; then
      echo "[post-merge] WARNING: No CI run found for devel @ ${SHORT_SHA}. Proceeding anyway."
    else
      echo "[post-merge] CI passed for devel @ ${SHORT_SHA}."
    fi
  fi

  echo "[post-merge] devel→main merge detected — bumping patch version..."
  npm version patch --no-git-tag-version
  NEW_VERSION=$(node -p "require('./package.json').version")
  git add package.json package-lock.json 2>/dev/null || git add package.json
  git commit -m "chore: bump version to ${NEW_VERSION}"
  echo "[post-merge] Version bumped to ${NEW_VERSION}"
  
  # Check npm auth before publishing
  echo "[post-merge] Checking npm authentication..."
  if ! npm whoami &>/dev/null; then
    echo "[post-merge] Not logged in to npm. Starting login (confirm in browser)..."
    npm login
    if ! npm whoami &>/dev/null; then
      echo "[post-merge] npm login failed. Please login and publish manually:"
      echo "[post-merge]   npm login && npm publish"
      echo ""
      exit 0
    fi
  fi
  NPM_USER=$(npm whoami 2>/dev/null)
  echo "[post-merge] Logged in as: ${NPM_USER}"

  # Publish to npm
  echo "[post-merge] Publishing version ${NEW_VERSION} to npm..."
  if npm publish --access public; then
    echo "[post-merge] Successfully published version ${NEW_VERSION} to npm!"
    echo "[post-merge] GitHub Actions will create a release shortly."
  else
    echo "[post-merge] Failed to publish to npm. Please publish manually:"
    echo "[post-merge]   npm publish"
  fi
  echo ""

  # Sync version bump back to devel so both branches stay in sync
  echo "[post-merge] Syncing version bump back to devel..."
  git push origin main 2>/dev/null || true
  git checkout devel
  git merge main --no-edit
  git push origin devel
  git checkout main
  echo "[post-merge] devel is now synced to ${NEW_VERSION}"
fi

# Run npm install if package.json changed in the merge
CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)
if echo "$CHANGED" | grep -q "package.json"; then
  echo "[post-merge] package.json changed — running npm install..."
  npm install
  echo "[post-merge] npm install complete."
fi

exit 0
