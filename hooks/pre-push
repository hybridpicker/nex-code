#!/bin/bash
# pre-push hook — scans pushed commits for secrets before allowing push.
# Install via: npm run install-hooks
#
# Bypass options:
#   NEX_FAST_PUSH=1          — skip all checks (secret scan + tests + benchmark)
#   NEX_SKIP_SECRET_CHECK=1  — skip secret scan only
#   NEX_SKIP_TESTS=1         — skip unit tests only
#   NEX_SKIP_BENCHMARK=1     — skip benchmark gate only
#   NEX_SLOW_TESTS=1         — run full suite incl. slow integration tests locally

set -euo pipefail

# ─── Load nvm so node/npm are available in non-interactive shells ──
# Git hooks don't source ~/.zshrc, so the nvm wrapper function (_load_nvm)
# is not defined. Loading nvm.sh directly puts the real node binary on PATH.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1091
  \. "$NVM_DIR/nvm.sh" 2>/dev/null || true
fi

# NEX_FAST_PUSH=1 skips all checks — useful after CI already validated the code
if [ "${NEX_FAST_PUSH:-0}" = "1" ]; then
  echo "[pre-push] All checks skipped (NEX_FAST_PUSH=1)"
  exit 0
fi

# Allow bypass
REMOTE="$1"
URL="${2:-}"

# Determine diff range — compare against remote tracking branch
LOCAL_REF=""
REMOTE_REF=""
while read local_ref local_sha remote_ref remote_sha; do
  LOCAL_REF="$local_ref"
  REMOTE_REF="$remote_ref"

  # If remote_sha is all zeros, this is a new branch — scan all commits
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$local_sha"
  else
    RANGE="${remote_sha}..${local_sha}"
  fi
done

if [ -z "$LOCAL_REF" ]; then
  # Nothing being pushed (e.g. delete)
  exit 0
fi

# Get the diff, excluding lock files, minified JS, built dist, and hook test fixtures
DIFF=$(git diff "$RANGE" -- . ':!*.lock' ':!*.min.js' ':!*.min.css' ':!package-lock.json' ':!yarn.lock' ':!dist/' ':!tests/hooks-pre-push.test.js' 2>/dev/null || true)

if [ -z "$DIFF" ]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

if [ "${NEX_SKIP_SECRET_CHECK:-0}" = "1" ]; then
  echo "[pre-push] Secret check skipped (NEX_SKIP_SECRET_CHECK=1)"
else
  if ! (cd "$REPO_ROOT" && node scripts/secret-scan.js --range "$RANGE"); then
    exit 1
  fi
fi

# ─── Unit Tests ────────────────────────────────────────────────
# Locally: runs only fast unit tests (~15s). Slow integration tests
# (git, ssh, hooks, tools) run in CI where NEX_SLOW_TESTS=1 or CI=true.
# Bypass via: NEX_SKIP_TESTS=1 git push

if [ "${NEX_SKIP_TESTS:-0}" = "1" ]; then
  echo "[pre-push] Tests skipped (NEX_SKIP_TESTS=1)"
else
  # In CI, run the full suite. Locally, skip known slow integration tests.
  if [ "${CI:-0}" = "true" ] || [ "${NEX_SLOW_TESTS:-0}" = "1" ]; then
    TEST_CMD="npm test --silent"
    echo "[pre-push] Running full test suite..."
  else
    SLOW_PATTERN="git\.test|ssh\.test|ssh-tools\.test|hooks\.test|hooks-pre-push\.test|tools\.test"
    TEST_CMD="npm test --silent -- --testPathIgnorePatterns='${SLOW_PATTERN}'"
    echo "[pre-push] Running fast tests (slow integration tests run in CI)..."
  fi

  if ! (cd "$REPO_ROOT" && eval "$TEST_CMD" 2>&1 | tail -5); then
    echo "[pre-push] Tests failed — retrying once (flaky test guard)..."
    if ! (cd "$REPO_ROOT" && eval "$TEST_CMD" 2>&1 | tail -5); then
      echo ""
      echo "╔══════════════════════════════════════════════════════════╗"
      echo "║  TESTS FAILED — push blocked                            ║"
      echo "╠══════════════════════════════════════════════════════════╣"
      echo "║  Fix failing tests before pushing.                      ║"
      echo "║  Bypass: NEX_SKIP_TESTS=1 git push                     ║"
      echo "║  Full suite: NEX_SLOW_TESTS=1 git push                 ║"
      echo "╚══════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
  fi
  echo "[pre-push] Tests passed."
fi

# ─── Benchmark Gate ─────────────────────────────────────────────
# Runs smoke-test benchmark and blocks push if quality/speed regressed.
# Bypass via: NEX_SKIP_BENCHMARK=1 git push

if [ "${NEX_SKIP_BENCHMARK:-0}" = "1" ]; then
  echo "[pre-push] Benchmark gate skipped (NEX_SKIP_BENCHMARK=1)"
else
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  GATE_SCRIPT="${REPO_ROOT}/scripts/benchmark-gate.js"

  if [ -f "$GATE_SCRIPT" ]; then
    echo "[pre-push] Running benchmark gate..."
    if ! node "$GATE_SCRIPT"; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════╗"
      echo "║  BENCHMARK REGRESSION — push blocked                    ║"
      echo "╠══════════════════════════════════════════════════════════╣"
      echo "║  Quality or speed regressed below baseline.             ║"
      echo "║  Review the output above for details.                   ║"
      echo "║                                                         ║"
      echo "║  Update baseline: npm run benchmark:gate -- --update-baseline"
      echo "║  Bypass: NEX_SKIP_BENCHMARK=1 git push                 ║"
      echo "╚══════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
  else
    echo "[pre-push] Warning: benchmark-gate.js not found, skipping gate"
  fi
fi

exit 0
