#!/bin/bash
# pre-push hook — scans pushed commits for secrets before allowing push.
# Install via: npm run install-hooks
# Bypass via: NEX_SKIP_SECRET_CHECK=1 git push

set -euo pipefail

# ─── Load nvm so node/npm are available in non-interactive shells ──
# Git hooks don't source ~/.zshrc, so the nvm wrapper function (_load_nvm)
# is not defined. Loading nvm.sh directly puts the real node binary on PATH.
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck disable=SC1091
  \. "$NVM_DIR/nvm.sh" 2>/dev/null || true
fi

# Allow bypass
if [ "${NEX_SKIP_SECRET_CHECK:-0}" = "1" ]; then
  echo "[pre-push] Secret check skipped (NEX_SKIP_SECRET_CHECK=1)"
  exit 0
fi

REMOTE="$1"
URL="${2:-}"

# Determine diff range — compare against remote tracking branch
LOCAL_REF=""
REMOTE_REF=""
while read local_ref local_sha remote_ref remote_sha; do
  LOCAL_REF="$local_ref"
  REMOTE_REF="$remote_ref"

  # If remote_sha is all zeros, this is a new branch — scan all commits
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$local_sha"
  else
    RANGE="${remote_sha}..${local_sha}"
  fi
done

if [ -z "$LOCAL_REF" ]; then
  # Nothing being pushed (e.g. delete)
  exit 0
fi

# Get the diff, excluding lock files, minified JS, built dist, and hook test fixtures
DIFF=$(git diff "$RANGE" -- . ':!*.lock' ':!*.min.js' ':!*.min.css' ':!package-lock.json' ':!yarn.lock' ':!dist/' ':!tests/hooks-pre-push.test.js' 2>/dev/null || true)

if [ -z "$DIFF" ]; then
  exit 0
fi

# Load allowlist (one pattern per line, lines starting with # are comments)
ALLOWLIST_FILE=".nex/push-allowlist"
ALLOWLIST=""
if [ -f "$ALLOWLIST_FILE" ]; then
  ALLOWLIST=$(grep -v '^\s*#' "$ALLOWLIST_FILE" | grep -v '^\s*$' || true)
fi

VIOLATIONS=""
VIOLATION_COUNT=0

# check_pattern <category> <regex>
check_pattern() {
  local category="$1"
  local pattern="$2"
  local matches

  matches=$(echo "$DIFF" | grep -nEi "$pattern" 2>/dev/null || true)

  if [ -z "$matches" ]; then
    return
  fi

  # Filter out allowlisted lines
  if [ -n "$ALLOWLIST" ]; then
    local filtered=""
    while IFS= read -r line; do
      local allowed=false
      while IFS= read -r allow_pattern; do
        if echo "$line" | grep -qF "$allow_pattern" 2>/dev/null; then
          allowed=true
          break
        fi
      done <<< "$ALLOWLIST"
      if [ "$allowed" = false ]; then
        filtered="${filtered}${line}\n"
      fi
    done <<< "$matches"
    matches=$(echo -e "$filtered" | sed '/^\s*$/d')
  fi

  if [ -n "$matches" ]; then
    VIOLATIONS="${VIOLATIONS}\n  [$category]\n${matches}\n"
    VIOLATION_COUNT=$((VIOLATION_COUNT + $(echo "$matches" | wc -l)))
  fi
}

# ─── Secret Patterns ────────────────────────────────────────

# API Keys — OpenAI, Anthropic, AWS, GitHub
check_pattern "API Key (sk-)" 'sk-[a-zA-Z0-9]{20,}'
check_pattern "AWS Access Key" 'AKIA[A-Z0-9]{16}'
check_pattern "GitHub Token (ghp_)" 'ghp_[a-zA-Z0-9]{36}'
check_pattern "GitHub OAuth (gho_)" 'gho_[a-zA-Z0-9]{36}'
check_pattern "GitHub App Token (ghs_)" 'ghs_[a-zA-Z0-9]{36}'
check_pattern "Slack Token" 'xox[bpors]-[a-zA-Z0-9-]+'

# Private Keys
check_pattern "Private Key" 'BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY'

# Hardcoded secrets in assignments
check_pattern "Hardcoded Secret" '(password|secret|token|api_key|apikey|api_secret|access_token|auth_token|credentials)\s*[:=]\s*['"'"'""][^'"'"'""]{8,}'

# SSH with IP addresses
check_pattern "SSH + IP" 'ssh\s+.*@[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+'

# .env style leaks (KEY=value where key suggests secret)
check_pattern ".env Leak" '^[+].*\b(API_KEY|SECRET_KEY|SECRET|TOKEN|PASSWORD|PRIVATE_KEY|ACCESS_KEY|AUTH_TOKEN|DB_PASSWORD|DATABASE_URL)\s*='

# ─── Result ──────────────────────────────────────────────────

if [ "$VIOLATION_COUNT" -gt 0 ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  SECRET DETECTED — push blocked                        ║"
  echo "╠══════════════════════════════════════════════════════════╣"
  echo -e "║  Found $VIOLATION_COUNT potential secret(s) in pushed commits:  "
  echo -e "$VIOLATIONS"
  echo "╠══════════════════════════════════════════════════════════╣"
  echo "║  To fix: remove secrets, amend commits, force-push.    ║"
  echo "║  To allowlist: add pattern to .nex/push-allowlist      ║"
  echo "║  To bypass: NEX_SKIP_SECRET_CHECK=1 git push           ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# ─── Unit Tests ────────────────────────────────────────────────
# Runs npm test before pushing. Bypass via: NEX_SKIP_TESTS=1 git push

if [ "${NEX_SKIP_TESTS:-0}" = "1" ]; then
  echo "[pre-push] Tests skipped (NEX_SKIP_TESTS=1)"
else
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  echo "[pre-push] Running unit tests..."
  if ! (cd "$REPO_ROOT" && npm test --silent 2>&1 | tail -5); then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  TESTS FAILED — push blocked                            ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    echo "║  Fix failing tests before pushing.                      ║"
    echo "║  Bypass: NEX_SKIP_TESTS=1 git push                     ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
  echo "[pre-push] Tests passed."
fi

# ─── Benchmark Gate ─────────────────────────────────────────────
# Runs smoke-test benchmark and blocks push if quality/speed regressed.
# Bypass via: NEX_SKIP_BENCHMARK=1 git push

if [ "${NEX_SKIP_BENCHMARK:-0}" = "1" ]; then
  echo "[pre-push] Benchmark gate skipped (NEX_SKIP_BENCHMARK=1)"
else
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  GATE_SCRIPT="${REPO_ROOT}/scripts/benchmark-gate.js"

  if [ -f "$GATE_SCRIPT" ]; then
    echo "[pre-push] Running benchmark gate..."
    if ! node "$GATE_SCRIPT"; then
      echo ""
      echo "╔══════════════════════════════════════════════════════════╗"
      echo "║  BENCHMARK REGRESSION — push blocked                    ║"
      echo "╠══════════════════════════════════════════════════════════╣"
      echo "║  Quality or speed regressed below baseline.             ║"
      echo "║  Review the output above for details.                   ║"
      echo "║                                                         ║"
      echo "║  Update baseline: npm run benchmark:gate -- --update-baseline"
      echo "║  Bypass: NEX_SKIP_BENCHMARK=1 git push                 ║"
      echo "╚══════════════════════════════════════════════════════════╝"
      echo ""
      exit 1
    fi
  else
    echo "[pre-push] Warning: benchmark-gate.js not found, skipping gate"
  fi
fi

exit 0
