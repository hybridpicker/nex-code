[Unit]
Description=nex-code weekly full benchmark
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/jarvis/nex-code
ExecStart=/usr/bin/node /home/jarvis/nex-code/scripts/benchmark-reallife.js
Environment=HOME=/home/jarvis
Environment=NODE_ENV=production
StandardOutput=append:/home/jarvis/nex-code/scripts/benchmark-results/weekly-bench.log
StandardError=append:/home/jarvis/nex-code/scripts/benchmark-results/weekly-bench.log
TimeoutStartSec=3600

[Install]
WantedBy=default.target
